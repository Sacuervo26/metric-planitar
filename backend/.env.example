PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Shared secret required in X-API-Key header on /cloud-state.
# Leave empty in dev to disable auth (backend will log a warning).
# REQUIRED in production — generate with: openssl rand -hex 32
API_KEY=

# Secret used to sign JWT session tokens for /auth/login.
# REQUIRED in production — generate with: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Cost factor for bcrypt password hashing. 12 is recommended.
BCRYPT_ROUNDS=12

# SQLite (default, zero-config)
DB_DIALECT=sqlite
DB_STORAGE=./data/metric-planitar.sqlite

# Postgres/MySQL (opcional — descomenta y llena)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=metric_planitar
# DB_USER=postgres
# DB_PASSWORD=postgres
